{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Auth": {
    "JwtKey": "",
    "Issuer": "CheckFlow.Api",
    "Audience": "CheckFlow.Web",
    "TokenExpirationMinutes": 480,
    "BootstrapSupervisor": {
      "Nome": "",
      "Sobrenome": "",
      "Email": "",
      "Senha": "",
      "ForceChangePassword": false,
      "IsMaster": true,
      "Ramal": null,
      "SetorNome": ""
    }
  },
  "LegacyHostingCompatibility": {
    "EnableRailwayEnvironmentFallback": true,
    "ApplyMigrationsOnStartup": true,
    "SeedOnStartup": true,
    "AllowVercelPreviewOrigins": true,
    "MySqlSslMode": "Disabled",
    "AllowPublicKeyRetrieval": true
  },
  "AllowedHosts": "*"
}
